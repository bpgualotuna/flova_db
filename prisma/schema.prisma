generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int           @id @default(autoincrement())
  nationalId    String        @unique @map("national_id") @db.VarChar(10)
  username      String        @unique @db.VarChar(50)
  password      String        @db.VarChar(255)
  fullName      String        @map("full_name") @db.VarChar(100)
  email         String?       @unique @db.VarChar(100)
  phone         String?       @db.VarChar(10)
  insuranceType String        @map("insurance_type") @db.VarChar(20)
  role          String        @default("paciente") @db.VarChar(20)
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  
  doctor        Doctor?
  appointments  Appointment[] @relation("PatientAppointments")
  
  @@index([nationalId])
  @@index([role])
  @@index([email])
  @@map("users")
}

model Doctor {
  id             Int            @id @default(autoincrement())
  userId         Int            @unique @map("user_id")
  specialty      String         @db.VarChar(100)
  licenseNumber  String         @unique @map("license_number") @db.VarChar(50)
  rating         Decimal        @default(0.0) @db.Decimal(2, 1)
  patientsServed Int            @default(0) @map("patients_served")
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules      WorkSchedule[]
  appointments   Appointment[]
  
  @@index([specialty])
  @@index([active])
  @@map("doctors")
}

model WorkSchedule {
  id         Int      @id @default(autoincrement())
  doctorId   Int      @map("doctor_id")
  dayOfWeek  Int      @map("day_of_week")
  startTime  String   @map("start_time") @db.VarChar(5)
  endTime    String   @map("end_time") @db.VarChar(5)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  
  doctor     Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  
  @@index([doctorId])
  @@index([dayOfWeek])
  @@map("work_schedules")
}

model Therapy {
  id           Int           @id @default(autoincrement())
  name         String        @db.VarChar(100)
  description  String        @db.Text
  specialty    String        @db.VarChar(100)
  duration     Int
  price        Decimal       @db.Decimal(10, 2)
  image        String?       @db.VarChar(255)
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  
  appointments Appointment[]
  
  @@index([specialty])
  @@index([active])
  @@map("therapies")
}

model Appointment {
  id                 Int      @id @default(autoincrement())
  patientId          Int      @map("patient_id")
  doctorId           Int      @map("doctor_id")
  therapyId          Int      @map("therapy_id")
  date               DateTime @db.Date
  time               String   @db.VarChar(5)
  status             String   @default("pending") @db.VarChar(20)
  symptoms           String   @db.Text
  hasExams           Boolean  @default(false) @map("has_exams")
  exams              String[] @default([])
  cancellationReason String?  @map("cancellation_reason") @db.Text
  doctorNotes        String?  @map("doctor_notes") @db.Text
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  
  patient            User     @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  doctor             Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  therapy            Therapy  @relation(fields: [therapyId], references: [id], onDelete: Cascade)
  
  @@unique([doctorId, date, time])
  @@index([patientId])
  @@index([doctorId])
  @@index([date])
  @@index([status])
  @@index([createdAt])
  @@map("appointments")
}

model BlacklistedToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.Text
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([token])
  @@index([expiresAt])
  @@map("blacklisted_tokens")
}

